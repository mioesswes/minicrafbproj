[Unit]
Description=GOYKARTA Node.js app
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/goykarta
Environment=NODE_ENV=production
EnvironmentFile=/var/www/goykarta/.env
ExecStart=/usr/bin/node /var/www/goykarta/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
